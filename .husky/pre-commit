#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# Run build
echo "Running build..."
npm run build
if [ $? -ne 0 ]; then
  echo "Build failed. Commit aborted."
  exit 1
fi

# Run tests (non-watch mode)
echo "Running tests..."
npm run test -- --run
if [ $? -ne 0 ]; then
  echo "Tests failed. Commit aborted."
  exit 1
fi

echo "All checks passed. Proceeding with commit."